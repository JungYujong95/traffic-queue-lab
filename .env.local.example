MYSQL_DATABASE=traffic_queue_lab
MYSQL_USER=traffic_user
MYSQL_PASSWORD=traffic_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

REDIS_PORT=6379

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/traffic_queue_lab?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=traffic_user
SPRING_DATASOURCE_PASSWORD=traffic_password
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=10
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=3000
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_FORMAT_SQL=false
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=3s
