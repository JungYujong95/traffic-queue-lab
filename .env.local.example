MYSQL_DATABASE=traffic_queue_lab
MYSQL_USER=traffic_user
MYSQL_PASSWORD=traffic_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

REDIS_PORT=6379

BACKEND_MEMORY_LIMIT=512m
BACKEND_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=60.0 -XX:InitialRAMPercentage=20.0 -XX:+ExitOnOutOfMemoryError
MYSQL_MEMORY_LIMIT=512m
REDIS_MEMORY_LIMIT=128m

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/traffic_queue_lab?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=traffic_user
SPRING_DATASOURCE_PASSWORD=traffic_password
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=3
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=3
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=1000
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_FORMAT_SQL=false
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=3s

APP_JWT_SECRET=traffic-queue-lab-local-jwt-secret-key-traffic-queue-lab
APP_JWT_ISSUER=traffic-queue-lab
APP_JWT_ACCESS_TOKEN_TTL=PT1H

APP_WAIT_QUEUE_WORKER_ENABLED=true
APP_WAIT_QUEUE_WORKER_COUPON_ID=1
APP_WAIT_QUEUE_WORKER_BATCH_SIZE=1
APP_WAIT_QUEUE_WORKER_FIXED_DELAY_MS=50
APP_WAIT_QUEUE_WORKER_LOCK_TTL=30s
APP_WAIT_QUEUE_RESULT_TTL=30m
